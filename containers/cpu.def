# Apptainer/Singularity image for the CPU (standard) toolchain.
#
# Much lighter than the CUDA image: the "minimal" AdaptiveCpp profile is CPU/OpenMP only and
# needs NO LLVM. Bakes a pre-built AdaptiveCpp (minimal) + pinned Boost into /opt/sdot-cache, and
# installs CPU builds of JAX and PyTorch in /opt/venv.
#
# Build (from the repo root):
#   apptainer build --fakeroot containers/cpu.sif containers/cpu.def
# Run the C++ test suite:
#   apptainer exec containers/cpu.sif python scripts/run_cpp_tests.py
#
# See containers/README.md for the APPTAINER_TMPDIR / APPTAINER_CACHEDIR disk-space setup.

Bootstrap: docker
From: ubuntu:24.04

%files
    requirements.txt /opt/sdot/requirements.txt
    tests /opt/sdot/tests
    src /opt/sdot/src

%environment
    # First candidate cache root.  Read-only at runtime; any new compilation falls through
    # to ~/.cache/sdot or /tmp.
    export SDOT_CACHE_DIR=/opt/sdot-cache
    export PATH=/opt/venv/bin:$PATH
    export DEBIAN_FRONTEND=noninteractive

%post
    set -eux

    export SDOT_ACPP_VERSION=v25.10.0
    export DEBIAN_FRONTEND=noninteractive
    export SDOT_CACHE_DIR=/opt/sdot-cache

    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential cmake ninja-build git ca-certificates \
        libomp-dev python3 python3-pip python3-venv
    # (g++ from build-essential provides OpenMP via libgomp; libomp-dev covers a clang fallback.)

    python3 -m venv /opt/venv
    /opt/venv/bin/pip install --no-cache-dir --upgrade pip
    /opt/venv/bin/pip install --no-cache-dir -r /opt/sdot/requirements.txt
    /opt/venv/bin/pip install --no-cache-dir jax
    /opt/venv/bin/pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu

    # Pre-build AdaptiveCpp (minimal) + pinned Boost into the in-image cache.
    PYTHONPATH=/opt/sdot/src/python /opt/venv/bin/python -c \
        "from sdot.compilation.adaptive_cpp import ensure_acpp; print('acpp:', ensure_acpp('minimal'))"

    chmod -R a+rX /opt/sdot-cache
    apt-get clean && rm -rf /var/lib/apt/lists/*

%test
    SDOT_CACHE_DIR=/opt/sdot-cache PYTHONPATH=/opt/sdot/src/python /opt/venv/bin/python -c \
        "from sdot.compilation.adaptive_cpp import is_available; assert is_available('minimal'), 'acpp missing'; print('acpp ok')"
    /opt/venv/bin/python -c "import jax, torch; print('jax', jax.__version__, '| torch', torch.__version__)"

%labels
    org.sdot.role  cpu-toolchain
    org.sdot.acpp  v25.10.0

%help
    CPU build+runtime image for sdot. AdaptiveCpp (minimal) is prebuilt in /opt/sdot-cache.
      apptainer exec containers/cpu.sif python scripts/run_cpp_tests.py
